# CUSTOS Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env.

# Runtime
ENV=development

# Auth (future)
# CUSTOS_API_KEY=your_key_here
# CUSTOS_JWT_SECRET=your_secret_here

# Observability (optional overrides)
# PROMETHEUS_PORT=9090
# GRAFANA_ADMIN_PASSWORD=change_me
