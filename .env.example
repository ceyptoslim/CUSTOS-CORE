# CUSTOS Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env.

# Runtime
ENV=production
LOG_LEVEL=INFO

# --- Authentication (custos/auth.py) ---------------------------------------
# JWT auth is ON by default. Set a strong secret in production.
CUSTOS_JWT_SECRET=change-me-to-a-long-random-secret
CUSTOS_JWT_EXPIRY=3600
# DEV/TEST ONLY -- disables JWT auth entirely. Never set in production.
# AUTH_DISABLED=1

# --- Audit persistence (custos/audit.py) ------------------------------------
# Leave both unset for in-memory (dev/test) audit storage.
# Set AUDIT_DB_PATH for single-node SQLite persistence:
# AUDIT_DB_PATH=/data/custos_audit.db
# Set DATABASE_URL for production PostgreSQL persistence (takes priority):
# DATABASE_URL=postgresql://user:pass@host:5432/custos

# --- Policy rule persistence (custos/policy_store.py) -----------------------
# Same pattern as audit persistence. Leave unset for in-memory (ephemeral)
# tenant policy rules. Set one of these so custom rules added via
# POST /v1/tenants/{tenant_id}/policy survive restarts:
# POLICY_DB_PATH=/data/custos_policy.db
# DATABASE_URL=postgresql://user:pass@host:5432/custos

# --- Tracing (custos/tracing.py) --------------------------------------------
# console (default) | disabled
# CUSTOS_TRACING=console
# Set to export spans to a real OTLP collector (Jaeger, Tempo, Honeycomb).
# Requires: pip install opentelemetry-sdk opentelemetry-exporter-otlp-proto-grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# --- Observability stack (docker-compose.yml) -------------------------------
# PROMETHEUS_PORT=9090
# GRAFANA_ADMIN_PASSWORD=change_me
