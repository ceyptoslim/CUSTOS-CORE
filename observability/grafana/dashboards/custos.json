{
  "id": null,
  "uid": "custos-main",
  "title": "CUSTOS Core — Governance Dashboard",
  "tags": ["custos", "ai-governance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "custos_requests_total",
          "legendFormat": "Total"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } }
      }
    },
    {
      "id": 2,
      "title": "Allowed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "custos_requests_allowed",
          "legendFormat": "Allowed"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }
      }
    },
    {
      "id": 3,
      "title": "Denied (Policy)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "custos_requests_denied",
          "legendFormat": "Denied"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    },
    {
      "id": 4,
      "title": "Rate Limited",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "custos_rate_limit_hits",
          "legendFormat": "Rate Limited"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },
    {
      "id": 5,
      "title": "Request Volume Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(custos_requests_total[1m]) * 60",
          "legendFormat": "Total req/min"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(custos_requests_denied[1m]) * 60",
          "legendFormat": "Denied req/min"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(custos_rate_limit_hits[1m]) * 60",
          "legendFormat": "Rate limited req/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "id": 6,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "custos_uptime_seconds",
          "legendFormat": "Uptime (s)"
        }
      ],
      "options": { "colorMode": "value" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ]
}
